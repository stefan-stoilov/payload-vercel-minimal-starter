{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 100,
  "semi": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    "**/payload-types.ts",
    ".tmp",
    "**/.git",
    "**/.hg",
    "**/.pnp.*",
    "**/.svn",
    "**/.yarn/**",
    "**/build",
    "**/dist/**",
    "**/node_modules",
    "**/temp",
    "**/docs/**",
    "tsconfig.json"
  ]
}
